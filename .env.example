# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-app.azurewebsites.net
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Azure AD (Microsoft Entra ID) ───────────────────────────────────────────
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── PostgreSQL (Azure Database for PostgreSQL Flexible Server) ───────────────
DATABASE_URL="postgresql://adminuser:password@your-server.postgres.database.azure.com:5432/approbations?sslmode=require"

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONTAINER_FACTURAS=facturas-documents

# ─── Microsoft Graph API (para búsqueda de usuarios y envío de email) ────────
# Usa el mismo CLIENT_ID/SECRET/TENANT de Azure AD arriba
GRAPH_USER_EMAIL=notifications@csdm.qc.ca

# ─── SGDI (intranet interna — solo accesible desde el servidor) ──────────────
SGDI_BASE_URL=https://intrati.csdm.qc.ca/SGDI/Projet/PrjDetail.aspx

# ─── Webhook correos entrantes ────────────────────────────────────────────────
# Cuenta que recibe las solicitudes por correo
WEBHOOK_ADMIN_EMAIL=admin@dynamixmtl.com
# Secreto aleatorio para validar notificaciones de Graph API
# Generar con: openssl rand -base64 32
WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Factura {
  id                      String                @id @default(cuid())
  nombreFactura           String
  noProjet                String
  srmProjet               String?
  // Opcionales: el PDF CertificatCR puede traerlos vacíos. Se completan luego
  // desde la app en vez de bloquear la ingesta o inventar registros fantasma.
  ecoleId                 String?
  fournisseurId           String?
  montant                 Decimal               @db.Decimal(12, 2)
  dateFacture             DateTime              @db.Date
  dateSaisie              DateTime              @default(now()) @db.Date
  dateLimite              DateTime?             @db.Date
  indiceComptable         String?
  affectationCredit       String?
  etatFacture             EstatusFactura        @default(OUVERT)
  responsableEmail        String
  cpEmail                 String?
  regisseurEmail          String?
  coordoEmail             String?
  dirAdjointeEmail        String?
  directionGeneraleEmail  String?
  cooEmail                String?
  responsableNombre       String?
  cpNombre                String?
  regisseurNombre         String?
  coordoNombre            String?
  dirAdjointeNombre       String?
  directionGeneraleNombre String?
  cooNombre               String?
  etatCP                  EstatusAprobador      @default(VACIO)
  etatRegisseur           EstatusAprobador      @default(VACIO)
  etatCoordo              EstatusAprobador      @default(VACIO)
  etatDirAdj              EstatusAprobador      @default(VACIO)
  etatDirGen              EstatusAprobador      @default(VACIO)
  repartitionRequise      Boolean               @default(false)
  raisonSocialConforme    Boolean               @default(false)
  dixPourcentVerifier     Boolean               @default(false)
  fourHomologue           Boolean               @default(false)
  paimentRapide           Boolean               @default(false)
  affectationCreditCheck  Boolean               @default(false)
  commentairesResponsable String?
  commentairesAdmin       String?
  bureauId                Int?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  adjuntosTemporal        AdjuntoTemporal[]
  documentos              Documento[]
  bureau                  Bureau?               @relation(fields: [bureauId], references: [id])
  ecole                   Ecole?                @relation(fields: [ecoleId], references: [id])
  fournisseur             Fournisseur?          @relation(fields: [fournisseurId], references: [id])
  historialAprobacion     HistorialAprobacion[]

  @@index([etatFacture])
  @@index([responsableEmail])
  @@index([cpEmail])
  @@index([regisseurEmail])
  @@index([coordoEmail])
  @@index([dirAdjointeEmail])
  @@index([directionGeneraleEmail])
  @@index([nombreFactura])
  @@index([createdAt])
}

model Fournisseur {
  id          String    @id @default(cuid())
  nombre      String
  razonSocial String?
  homologue   Boolean   @default(false)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  facturas    Factura[]

  @@index([nombre])
  @@index([activo])
}

model Ecole {
  id        String    @id @default(cuid())
  nombre    String
  codigo    String?   @unique
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())
  facturas  Factura[]

  @@index([nombre])
  @@index([activo])
}

model Documento {
  id          String        @id @default(cuid())
  facturaId   String
  nombre      String
  contentType String        @default("application/octet-stream")
  tamano      Int
  tipo        TipoDocumento @default(PRINCIPAL)
  createdAt   DateTime      @default(now())
  contenido   Bytes
  factura     Factura       @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
  @@index([tipo])
}

model AdjuntoTemporal {
  id          String   @id @default(cuid())
  idSolicitud String
  facturaId   String?
  nombre      String
  contentType String   @default("application/octet-stream")
  tamano      Int
  createdAt   DateTime @default(now())
  contenido   Bytes
  factura     Factura? @relation(fields: [facturaId], references: [id])

  @@index([idSolicitud])
  @@index([facturaId])
}

model HistorialAprobacion {
  id              String           @id @default(cuid())
  facturaId       String
  rolAprobador    String
  emailAprobador  String
  nombreAprobador String?
  decision        EstatusAprobador
  comentario      String?
  createdAt       DateTime         @default(now())
  factura         Factura          @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
  @@index([emailAprobador])
}

model Bureau {
  id       Int       @id @default(autoincrement())
  nombre   String
  email    String    @unique
  facturas Factura[]
}

model Version {
  id      Int      @id @default(autoincrement())
  version String
  fecha   DateTime @default(now())
  notas   String?
}

// ─── NextAuth v5 — requerido por @auth/prisma-adapter ────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum EstatusFactura {
  OUVERT
  EN_COURS
  APPROUVE
  REFUSE
  PAYE
}

enum EstatusAprobador {
  EN_COURS
  APPROUVE
  REFUSE
  VACIO
}

enum TipoDocumento {
  PRINCIPAL
  CREDITO
  ADJUNTO
}
